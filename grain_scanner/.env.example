# Copy to .env and adjust values before running.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Grain Scanner"
APP_VERSION="1.0.0"
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="sqlite+aiosqlite:///./grain_scanner.db"

# ── Paths ────────────────────────────────────────────────────────────────────
UPLOAD_DIR="data/uploads"
OUTPUT_DIR="outputs"
CALIBRATION_FILE="data/calibration.json"

# ── Scanner defaults ─────────────────────────────────────────────────────────
DEFAULT_DPI=300

# ── Vision pipeline ───────────────────────────────────────────────────────────
MIN_GRAIN_AREA_PX=50
MAX_GRAIN_AREA_PX=5000000
GAUSSIAN_BLUR_KERNEL=5
ADAPTIVE_BLOCK_SIZE=51
ADAPTIVE_C=10
MORPH_KERNEL_SIZE=3
WATERSHED_MIN_DISTANCE=20

# ── API ──────────────────────────────────────────────────────────────────────
API_PREFIX="/api/v1"
MAX_UPLOAD_SIZE_MB=100
ALLOWED_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ── Streamlit frontend ───────────────────────────────────────────────────────
BACKEND_URL="http://localhost:8000"
